HOST=0.0.0.0
PORT=8787

# Relay service settings. These are the only required settings for relay-only mode.
RELAY_STORAGE_DIR=./data/chunked-requests
RELAY_REQUEST_TTL_MS=900000
# RELAY_SHARED_SECRET=

# Proxy-mode settings. Only needed when this service itself will call Codex /v1/responses.
CODEX_BASE_URL=https://chatgpt.com/backend-api
CODEX_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
CODEX_ORIGINATOR=codex-proxy
CODEX_DEFAULT_MODEL=gpt-5.4
CODEX_ALLOWED_MODELS=gpt-5.4,gpt-5.3-codex,gpt-5.2-codex,gpt-5.1-codex,gpt-5.1-codex-mini
ALLOW_CLIENT_AUTH_BEARER=false

# Choose one of the auth modes below only for proxy-mode.
# 1) Directly provide a current ChatGPT OAuth access token:
# CODEX_ACCESS_TOKEN=
#
# 2) Or provide a refresh token and let the proxy mint/refresh access tokens:
# CODEX_REFRESH_TOKEN=
# CODEX_ACCOUNT_ID=
